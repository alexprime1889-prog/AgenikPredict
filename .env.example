# LLM API Configuration (OpenRouter recommended for Anthropic Claude)
# Get your API key at: https://openrouter.ai/
# Note: simulations can be costly, start with <40 rounds
LLM_API_KEY=your_openrouter_api_key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=anthropic/claude-sonnet-4.6

# ===== OpenAI Direct (Whisper transcription for video/audio) =====
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===== Zep Memory Graph Configuration =====
# Free monthly quota is sufficient for basic use: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM Configuration (optional) =====
# Only include these if you want a separate faster model for certain tasks
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Authentication =====
# JWT signing secret (auto-generated if not set)
# JWT_SECRET=your_random_secret_here

# Email service for magic link emails
# If not set, magic links are printed to server console (dev mode)
# RESEND_FROM_EMAIL=AgenikPredict <noreply@yourdomain.com>

# Public URL of your app (for magic link URLs)
# APP_URL=https://app.agenikpredict.com

# ===== Market Data (optional) =====
# Twelve Data API key for real-time stock/crypto market data
# Free tier: 800 API credits/day — https://twelvedata.com/
PERPLEXITY_API_KEY=
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
# TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
# LIVE_EVIDENCE_ENABLED=true
# LIVE_NEWS_TIMEOUT_SECONDS=4
# LIVE_NEWS_MAX_ITEMS=5
# LIVE_EVIDENCE_CACHE_TTL_SECONDS=300

# ===== Production Settings =====
# Set to False in production
# FLASK_DEBUG=False

# ===== Task / Worker Cutover =====
# Keep inline on the web service until a separate active worker is proven safe
# SERVICE_ROLE=web
# TASK_EXECUTION_MODE=inline
# TASK_STORE_MODE=dual
# TASK_READ_SOURCE=fallback
# WORKER_STANDBY=false
# WORKER_HEALTHCHECK_URL=http://agenikpredictworker.railway.internal/health
# WORKER_HEALTHCHECK_TIMEOUT_SECONDS=2.5

# ===== Artifact Storage =====
# Local storage is safe only for single-process / inline execution.
# For a separate worker service, use a shared filesystem that is truly shared
# by both services, or use object_store with an S3-compatible bucket and local scratch cache.
# ARTIFACT_STORAGE_MODE=local
# ARTIFACT_ROOT=/app/backend/uploads
# ARTIFACT_BUCKET=agenikpredict-artifacts
# ARTIFACT_PREFIX=agenikpredict
# ARTIFACT_ENDPOINT=https://s3.amazonaws.com
# ARTIFACT_REGION=us-east-1
# ARTIFACT_ACCESS_KEY_ID=your_access_key_id
# ARTIFACT_SECRET_ACCESS_KEY=your_secret_access_key
# ARTIFACT_OBJECT_FORCE_PATH_STYLE=true
# ARTIFACT_OBJECT_CONNECT_TIMEOUT_SECONDS=5
# ARTIFACT_OBJECT_READ_TIMEOUT_SECONDS=10
# ARTIFACT_SCRATCH_DIR=/tmp/agenikpredict-artifacts
# ARTIFACT_PROBE_ON_STARTUP=true
